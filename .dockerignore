# Build context is the repo root (docker/Dockerfile builds from `..`), so this
# root .dockerignore is the one BuildKit actually applies. Keep secrets, VCS,
# caches, tests, and docs out of the image layers (Hardening Standard v1 §1).
.git/
.gitignore
.gitattributes
.github/
__pycache__/
*.py[cod]
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
.eggs/
wheels/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.nox/
.tox/
.cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.env
.env.*
!.env.example
!.env.docker.example
docs/
tests/
scripts/
data/
*.db
*.sqlite
*.sqlite3
*.parquet
*.feather
*.log
logs/
.DS_Store

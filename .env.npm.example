# StringDB-Link NPM Production Environment Configuration
# Copy this file to .env.npm and customize for your NPM deployment

# NPM Network Configuration
NPM_SHARED_NETWORK_NAME=npm_default

# Public Domain Configuration
STRINGDB_LINK_PUBLIC_DOMAIN=stringdb.yourdomain.com
STRINGDB_LINK_PUBLIC_URL=https://stringdb.yourdomain.com

# Server Configuration (Production)
STRINGDB_LINK_HOST=0.0.0.0
STRINGDB_LINK_PORT=8000
STRINGDB_LINK_LOG_LEVEL=INFO
STRINGDB_LINK_LOG_FORMAT=json
STRINGDB_LINK_RELOAD=false

# CORS Configuration for Production (JSON format required)
STRINGDB_LINK_CORS_ORIGINS=["https://stringdb.yourdomain.com"]
STRINGDB_LINK_CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
STRINGDB_LINK_CORS_ALLOW_HEADERS=["*"]
STRINGDB_LINK_CORS_ALLOW_CREDENTIALS=true

# STRING API Configuration
STRINGDB_LINK_STRINGDB_API_BASE_URL=https://string-db.org
STRINGDB_LINK_STRINGDB_API_RATE_LIMIT_CALLS=10
STRINGDB_LINK_STRINGDB_API_RATE_LIMIT_PERIOD=60
STRINGDB_LINK_STRINGDB_API_TIMEOUT=30
STRINGDB_LINK_STRINGDB_API_MAX_RETRIES=3

# Production Caching Configuration (Longer TTLs)
STRINGDB_LINK_CACHE_IDENTIFIERS_TTL=7200
STRINGDB_LINK_CACHE_NETWORKS_TTL=3600
STRINGDB_LINK_CACHE_ENRICHMENT_TTL=7200
STRINGDB_LINK_CACHE_ANNOTATIONS_TTL=14400
STRINGDB_LINK_CACHE_HOMOLOGY_TTL=86400
STRINGDB_LINK_CACHE_IMAGES_TTL=7200

# Performance Configuration (Production)
STRINGDB_LINK_PERFORMANCE_MAX_CONCURRENT_REQUESTS=200
STRINGDB_LINK_PERFORMANCE_REQUEST_TIMEOUT=30
STRINGDB_LINK_PERFORMANCE_CONNECTION_TIMEOUT=10

# Security Configuration (Production)
STRINGDB_LINK_SECURITY_API_KEY_HEADER=X-API-Key
STRINGDB_LINK_SECURITY_ALLOWED_HOSTS=["stringdb.yourdomain.com", "yourdomain.com"]

# MCP Configuration
STRINGDB_LINK_MCP_SERVER_NAME=stringdb-link
STRINGDB_LINK_MCP_SERVER_VERSION=0.1.0

# Production Gunicorn Settings
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_LOG_LEVEL=warning

# Additional Production Settings
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=50
GUNICORN_PRELOAD_APP=true
GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
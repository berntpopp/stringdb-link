[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    .tox,
    .eggs,
    *.egg-info,
    .pytest_cache

# Ignore specific errors:
# E203: whitespace before ':' (conflicts with black/ruff format)
# W503: line break before binary operator (conflicts with black/ruff format)

per-file-ignores =
    tests/*:D,S,PLR,ANN,T20
    scripts/*:E402,D202
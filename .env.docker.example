# Docker environment for stringdb-link behind Nginx Proxy Manager.
# Copy to .env.docker for the NPM compose deployment:
#
#   cp .env.docker.example .env.docker
#
# docker-compose.npm.yml interpolates the variables below; pin them so the
# server-side `cp .env.docker.example .env.docker` yields a working --env-file.

# ---- Nginx Proxy Manager (docker-compose.npm.yml) ----
# External NPM network the container joins for reverse-proxy routing.
NPM_SHARED_NETWORK_NAME=npm_default

# ---- Public addressing ----
PUBLIC_DOMAIN=stringdb-link.genefoundry.org
PUBLIC_URL=https://stringdb-link.genefoundry.org
ALLOWED_HOSTS=["localhost","127.0.0.1","::1","stringdb-link.genefoundry.org"]
ALLOWED_ORIGINS=[]

# ---- CORS ----
# pydantic-settings JSON-decodes complex (list) env values before model
# validators run, so this MUST be a JSON array string (not comma-separated).
CORS__ALLOW_ORIGINS=["https://stringdb-link.genefoundry.org"]

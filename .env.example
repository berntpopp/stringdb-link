# StringDB-Link Environment Configuration

# Server Configuration
HOST=127.0.0.1
PORT=8000
TRANSPORT=unified
RELOAD=false

# StringDB API Configuration
STRINGDB_BASE_URL=https://version-12-0.string-db.org/api
STRINGDB_REQUEST_TIMEOUT=30
STRINGDB_RATE_LIMIT_DELAY=1.0
STRINGDB_MAX_RETRIES=3
STRINGDB_RETRY_DELAY=1.0

# Caching Configuration
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=3600
CACHE_IDENTIFIER_TTL=86400
CACHE_NETWORK_TTL=43200
CACHE_ENRICHMENT_TTL=21600
CACHE_IMAGE_TTL=7200
CACHE_MAX_SIZE=1000

# CORS Configuration
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# MCP Configuration
MCP_PATH=/mcp
MCP_SERVER_NAME=StringDB-Link Server

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs/stringdb-link.log
LOG_FILE_MAX_SIZE=10485760
LOG_FILE_BACKUP_COUNT=5

# Development Configuration
DEBUG=false
DEVELOPMENT_MODE=false

# Security Configuration
API_KEY_REQUIRED=false
API_KEY_HEADER=X-API-Key
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Performance Configuration
MAX_CONCURRENT_REQUESTS=100
CONNECTION_POOL_SIZE=20
CONNECTION_POOL_MAX_SIZE=100
KEEPALIVE_TIMEOUT=5

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
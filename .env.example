# StringDB-Link Environment Configuration
# Copy this file to .env and customize for your environment

# Server Configuration
STRINGDB_LINK_HOST=127.0.0.1
STRINGDB_LINK_PORT=8000
STRINGDB_LINK_LOG_LEVEL=INFO
STRINGDB_LINK_LOG_FORMAT=text
STRINGDB_LINK_RELOAD=false

# CORS Configuration (JSON format required for arrays)
STRINGDB_LINK_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
STRINGDB_LINK_CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
STRINGDB_LINK_CORS_ALLOW_HEADERS=["*"]
STRINGDB_LINK_CORS_ALLOW_CREDENTIALS=true

# STRING API Configuration
STRINGDB_LINK_STRINGDB_API_BASE_URL=https://string-db.org
STRINGDB_LINK_STRINGDB_API_RATE_LIMIT_CALLS=10
STRINGDB_LINK_STRINGDB_API_RATE_LIMIT_PERIOD=60
STRINGDB_LINK_STRINGDB_API_TIMEOUT=30
STRINGDB_LINK_STRINGDB_API_MAX_RETRIES=3

# Caching Configuration
STRINGDB_LINK_CACHE_IDENTIFIERS_TTL=3600
STRINGDB_LINK_CACHE_NETWORKS_TTL=1800
STRINGDB_LINK_CACHE_ENRICHMENT_TTL=3600
STRINGDB_LINK_CACHE_ANNOTATIONS_TTL=7200
STRINGDB_LINK_CACHE_HOMOLOGY_TTL=86400
STRINGDB_LINK_CACHE_IMAGES_TTL=3600

# Performance Configuration
STRINGDB_LINK_PERFORMANCE_MAX_CONCURRENT_REQUESTS=100
STRINGDB_LINK_PERFORMANCE_REQUEST_TIMEOUT=30
STRINGDB_LINK_PERFORMANCE_CONNECTION_TIMEOUT=10

# Security Configuration
STRINGDB_LINK_SECURITY_API_KEY_HEADER=X-API-Key
STRINGDB_LINK_SECURITY_ALLOWED_HOSTS=["*"]

# MCP Configuration
STRINGDB_LINK_MCP_SERVER_NAME=stringdb-link
STRINGDB_LINK_MCP_SERVER_VERSION=0.1.0

# Production Settings (for Gunicorn)
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_LOG_LEVEL=info
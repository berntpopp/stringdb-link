# StringDB-Link Environment Configuration
# Copy this file to .env and customize for your environment.
#
# Settings use Pydantic's nested delimiter: SECTION__FIELD.

# Server Configuration
HOST=127.0.0.1
PORT=8000
TRANSPORT=unified
RELOAD=false
ALLOWED_HOSTS=["localhost","127.0.0.1","::1"]
ALLOWED_ORIGINS=[]

# Logging Configuration
LOGGING__LEVEL=INFO
LOGGING__FORMAT=text

# CORS Configuration
CORS__ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS__ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS__ALLOW_HEADERS=["*"]
CORS__ALLOW_CREDENTIALS=true

# STRING API Configuration
STRINGDB_API__BASE_URL=https://version-12-0.string-db.org/api
STRINGDB_API__RATE_LIMIT_PER_SECOND=1.0
STRINGDB_API__TIMEOUT=30
STRINGDB_API__MAX_RETRIES=3
STRINGDB_API__RETRY_DELAY=1.0

# Caching Configuration
CACHE__ENABLED=true
CACHE__DEFAULT_TTL=3600
CACHE__IDENTIFIER_TTL=86400
CACHE__NETWORK_TTL=43200
CACHE__ENRICHMENT_TTL=21600
CACHE__IMAGE_TTL=7200
CACHE__MAX_SIZE=1000

# Performance Configuration
PERFORMANCE__MAX_CONCURRENT_REQUESTS=100
PERFORMANCE__CONNECTION_POOL_SIZE=20
PERFORMANCE__CONNECTION_POOL_MAX_SIZE=100
PERFORMANCE__KEEPALIVE_TIMEOUT=5

# Security Configuration
SECURITY__API_KEY_REQUIRED=false
SECURITY__API_KEY_HEADER=X-API-Key
SECURITY__RATE_LIMIT_ENABLED=true
SECURITY__RATE_LIMIT_REQUESTS=100
SECURITY__RATE_LIMIT_WINDOW=60

# MCP Configuration
MCP__PATH=/mcp
MCP__SERVER_NAME=StringDB-Link Server
